PORT=5001
NODE_ENV=development

# PostgreSQL
POSTGRES_URI=postgresql://user:password@localhost:5432/thriftcircle

# MongoDB
MONGO_URI=mongodb://localhost:27017/thriftcircle

# JWT
ACCESS_TOKEN_SECRET=your_access_secret_here
REFRESH_TOKEN_SECRET=your_refresh_secret_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (RazorpayX keys recommended for escrow + payouts)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

# Shiprocket
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_WEBHOOK_SECRET=

# Email (Gmail)
EMAIL_USER=
EMAIL_PASS=

# Admin
ADMIN_EMAIL=admin@thriftcircle.com
ADMIN_PASSWORD=Admin@123

# Frontend URL
FRONTEND_URL=http://localhost:3000
