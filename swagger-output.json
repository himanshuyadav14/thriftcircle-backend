                  },
                  "state": {
                    "type": "string"
                  },
                  "images": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                },
                "required": [
                  "title",
                  "description",
                  "price",
                  "category_id",
                  "size",
                  "condition",
                  "images"
                ]
              }
            }
          }
